{
  "name": "boocontext",
  "version": "1.16.0",
  "description": "MCP codebase context server: routes, schema, call graphs, health, type recovery. AST precision, one npx call.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "boocontext": "dist/index.js",
    "boocontext-mcp": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./plugins/terraform": "./dist/plugins/terraform/index.js",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "eval",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "npm run build && tsx --test tests/*.test.ts",
    "compile": "bun build ./src/index.ts --target=bun --outfile=boocontext --compile",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "boocontext",
    "context",
    "mcp",
    "model-context-protocol",
    "codebase-context",
    "code-analysis",
    "code-intelligence",
    "static-analysis",
    "ast",
    "repo-map",
    "call-graph",
    "ai-agents",
    "ai-context",
    "developer-tools",
    "cli"
  ],
  "author": "indifferentketchup <sam@indifferentketchup.com>",
  "contributors": [
    "Kailesk Khumar (HouseofMVPs, https://houseofmvps.com)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/indifferentketchup/boocontext.git"
  },
  "homepage": "https://github.com/indifferentketchup/boocontext#readme",
  "bugs": {
    "url": "https://github.com/indifferentketchup/boocontext/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
